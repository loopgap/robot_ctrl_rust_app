# Generated by Cargo
# will have compiled files and executables
debug
target
/target/
/robot_control_rust/target/

# Cargo lock is usually committed for binaries
#! Cargo.lock

# Build / temp outputs
dist/
build/
out/
tmp/
temp/
*.tmp
*.bak
/release_artifacts/
/robot_control_rust/release_artifacts/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Logs
*.log
logs/
/robot_control_rust/logs/
/smoke_logs/
/smoke_logs_local*/
/robot_control_rust/smoke_logs/
/robot_control_rust/smoke_logs_local*/

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# IDE / editor
.idea/
.vscode/
*.code-workspace

# OS / file explorer
.DS_Store
Thumbs.db
Desktop.ini

# Python cache (if any tooling script exists)
__pycache__/
*.pyc

# Environment files
.env
.env.*

# Keep installer outputs only if explicitly needed
*.7z
*.zip


# Swap files (vim, others)
*.swp
*.swo
*~*

# Local environment overrides
.env.local

# Code coverage
coverage/

# Profiling data
*.profraw
