{
  "version": "1.0.0",
  "workspace": {
    "allowedRootEntries": [
      ".git",
      ".github",
      ".gitignore",
      "deny.toml",
      "docs",
      "LICENSE",
      "make.ps1",
      "Makefile",
      "README.md",
      "release_notes",
      "robot_control_rust",
      "route.md",
      "rust_tools_suite",
      "scripts",
      ".cargo-advisory-db",
      ".vscode",
      ".idea"
    ],
    "allowedRootRegex": [
      "^.+\\.code-workspace$"
    ],
    "blockedPathRegex": [
      "(?:^|/)smoke_logs(?:/|$)",
      "(?:^|/)smoke_logs_local[^/]*(?:/|$)",
      "(?:^|/)release_artifacts(?:/|$)",
      "(?:^|/)logs(?:/|$)",
      "^(tmp|temp|out|dist|build)(?:/|$)"
    ],
    "blockedFixedRelativePaths": [
      "smoke_logs",
      "robot_control_rust/smoke_logs",
      "release_artifacts",
      "robot_control_rust/release_artifacts",
      "logs",
      "robot_control_rust/logs",
      "tmp",
      "temp",
      "out",
      "dist",
      "build",
      "robot_control_rust/dist",
      ".cargo-advisory-db..lock"
    ],
    "blockedGlobPatterns": [
      "smoke_logs_local*",
      "robot_control_rust/smoke_logs_local*"
    ]
  },
  "cleanup": {
    "fixedRelativePaths": [
      "smoke_logs",
      "robot_control_rust/smoke_logs",
      "release_artifacts",
      "robot_control_rust/release_artifacts",
      "logs",
      "robot_control_rust/logs",
      "tmp",
      "temp",
      "out",
      "dist",
      "build",
      "robot_control_rust/dist",
      ".cargo-advisory-db..lock"
    ],
    "globPatterns": [
      "smoke_logs_local*",
      "robot_control_rust/smoke_logs_local*"
    ],
    "protectedRelativePaths": [
      ".git",
      ".github",
      "docs",
      "scripts",
      "release_notes",
      "robot_control_rust/src",
      "rust_tools_suite/src"
    ]
  }
}
